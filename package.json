{
  "name": "Flamby",
  "version": "1.0.3",
  "description": "My Custom Browser",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.Flamby.app",
    "productName": "Flamby",
    "win": {
      "target": "nsis",
      "icon": "Flamby.ico"
    },
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "samratdas5703",
      "repo": "Flamby"
    }
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.0",
    "cross-fetch": "^4.1.0",
    "electron-updater": "^6.8.9"
  }
}